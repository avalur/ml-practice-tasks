// Phase 2 schema. Auth.js models + app models (problems, submissions, progress).
// clientStatus/verifiedStatus are kept distinct from day one: solving is verified
// client-side (Pyodide), so progress is "client-solved" until a future server-side
// re-verification pass flips verifiedSolved.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- Auth.js (NextAuth) models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  submissions   Submission[]
  progress      UserProblemProgress[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

model Problem {
  id          String   @id // "topic/slug"
  topic       String
  slug        String
  title       String
  difficulty  String
  contentHash String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]
  progress    UserProblemProgress[]

  @@unique([topic, slug])
}

model Submission {
  id             String   @id @default(cuid())
  userId         String
  problemId      String
  code           String   @db.Text
  clientStatus   String // "passed" | "failed" | "error" | "timeout"
  verifiedStatus String? // server re-verification (future)
  passed         Int
  total          Int
  durationMs     Int?
  runnerVersion  String?
  pyodideVersion String?
  errorKind      String?
  createdAt      DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, problemId])
  @@index([createdAt])
}

model UserProblemProgress {
  id               String    @id @default(cuid())
  userId           String
  problemId        String
  clientSolved     Boolean   @default(false)
  verifiedSolved   Boolean   @default(false)
  attemptCount     Int       @default(0)
  bestPassed       Int       @default(0)
  bestTotal        Int       @default(0)
  solvedAt         DateTime?
  lastSubmittedAt  DateTime?
  bestSubmissionId String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}
